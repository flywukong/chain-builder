# ── BNB Chain Ops 部署配置 ── cp 到 .env 后填写(.env 不入库)

# 端口(单进程托管 前端+API+WS)
PORT=8080

# BSC RPC / WSS —— 决定链上实时数据源(区块流 / MEV / 交易采样)
# 用带 key 的 nodereal,或内网 fullnode(需支持 eth_subscribe newHeads)
# 不填则回落到公共节点 https://bsc-dataseed.bnbchain.org(限流,无 WSS,仅保证可启动)
BSC_RPC_URL=https://bsc-mainnet-ap.nodereal.io/v1/<your-key>
BSC_WS_URL=wss://bsc-mainnet-ap.nodereal.io/ws/v1/<your-key>

# keter 指标 API 鉴权(内网 ELB;JSON 内含 JWT token)
# 缺失时:监控/存储/流量页的 keter 指标不可用;交易分析/MEV/首页 Ring 不受影响
# 建议申请服务账号 token,勿用个人长效 token
KETER_CONFIG_FILE=/etc/bnbchain-ops/keter.json
# keter 端点覆盖:默认走 https://keter-api.toolsapple.net(需内网 DNS 可解析该域名)。
# 若机器到不了该地址、但能通过内网 Host 路由访问 keter,改走内网入口 + Host 头:
# KETER_API_BASE=http://nodereal-nonprod.vminsert.internal
# KETER_HOST_HEADER=keter-api.monitor.internal

# AI 后端:auto(默认,有 ANTHROPIC_API_KEY 走 claude-api 否则 claude-cli)
#          claude-cli / claude-api / codex-cli / codex-api / codex-py
AI_BACKEND=auto

# Claude:设了 key 走官方 SDK(服务器用这个);不设则回落本地已登录 claude CLI(开发机)
ANTHROPIC_API_KEY=
# 可选:默认 claude-opus-4-8;降本可设 claude-haiku-4-5 / claude-sonnet-5(仅 claude-api 路径)
ANTHROPIC_MODEL=
# 可选:claude-cli 路径的模型(--model 透传,如 sonnet / opus / haiku);不设用 CLI 登录账号默认
CLAUDE_CLI_MODEL=

# Codex(对比用):
#  codex-cli 复用本地已登录的 codex,免 key。⚠️ ChatGPT 账号默认模型(gpt-5.x-codex)用不了,须指定支持的如 gpt-5.5
CODEX_MODEL=gpt-5.5
#  codex-api / codex-py 走 OpenAI(需 key)。codex-py = 调 Python venv 里的 openai SDK(服务器 Node 有问题时用)
#    venv 装法:python3 -m venv ~/openai-venv && ~/openai-venv/bin/pip install -U openai
OPENAI_API_KEY=                                  # codex-api / codex-py 用
OPENAI_MODEL=gpt-5.5                             # 默认 gpt-5.5;OpenAI API 账号需有该模型权限
PYTHON_BIN=                                       # codex-py 用,指到 venv 如 ~/openai-venv/bin/python

# 可选:BscScan API key —— 未知合约取 verified 名称/proxy(getsourcecode)
BSCSCAN_API_KEY=

# 可选:采样机器覆盖(默认见 metrics.js / addrIntel)
# INSERT_LAT_IPS=10.211.31.89,10.211.32.195,10.211.32.143,10.213.31.163
# DB_SAMPLE_IPS=10.211.31.89,10.211.32.195,10.211.32.143
